# Coturn configuration for p2p-collab
# Generated from .env — do not edit directly

listening-port=3478
tls-listening-port=5349

fingerprint

realm=${TURN_REALM}
server-name=${TURN_REALM}

use-auth-secret
static-auth-secret=${TURN_SECRET}

min-port=${TURN_MIN_PORT}
max-port=${TURN_MAX_PORT}

# Quotas to prevent abuse
stale-nonce=600
user-quota=12
total-quota=200

# External IP if behind NAT
# external-ip=PUBLIC_IP/LAN_IP

no-multicast-peers

log-file=stdout
verbose