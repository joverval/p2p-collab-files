{
  "name": "p2p-collab-files",
  "version": "0.1.0",
  "description": "Real-time collaborative markdown editor — browser-to-browser P2P with WebRTC, Yjs CRDT, and CodeMirror 6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "relay": "node server/ws-relay.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run typecheck && npm run test:unit && npm run build && npm run test:e2e",
    "check": "npm run test:all",
    "bootstrap": "bash scripts/bootstrap.sh",
    "audit": "npm audit --audit-level=high"
  },
  "author": "Joaquín Vergara",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joverval/p2p-collab-files"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.1",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.12",
    "ws": "^8.21.1",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/dompurify": "^3.0.5",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "start-server-and-test": "^3.0.11",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
