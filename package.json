{
  "name": "p2p-collab-files",
  "version": "0.1.0",
  "description": "Real-time collaborative markdown editor — browser-to-browser P2P with WebRTC, Yjs CRDT, and CodeMirror 6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "relay": "node server/ws-relay.js",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests yet — run: node scripts/test-relay.js'",
    "test:e2e": "node scripts/test-relay.js",
    "check": "npm run typecheck && npm run build",
    "bootstrap": "bash scripts/bootstrap.sh"
  },
  "author": "Joaquín Vergara",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joverval/p2p-collab-files"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.1",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.12",
    "ws": "^8.21.1",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
