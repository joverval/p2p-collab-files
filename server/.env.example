# p2p-collab-files relay configuration
# Copy to server/.env and fill in the values

# TURN server (coturn)
TURN_ENABLED=0
TURN_HOST=
TURN_SECRET=
# TURN_TTL=3600  # credential lifetime in seconds (default: 3600)

# CORS / WS allowlist (comma-separated)
APP_ORIGINS=https://joverval.cl,http://localhost:8082

# Relay port
PORT=8083

# Environment (production | development)
NODE_ENV=development
